{
  "entities": {
    "Stream": {
      "title": "Stream",
      "description": "A cohort of students",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Stream name, e.g., Поток 45" },
        "blockDates": {
          "type": "object",
          "description": "Map of block number (1-14) to opening date (ISO string or timestamp)"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "A student in a stream",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "streamId": { "type": "string" },
        "streamName": { "type": "string" },
        "currentBlock": { "type": "number" },
        "expectedBlock": { "type": "number" },
        "delta": { "type": "number" },
        "status": { "type": "string", "enum": ["not_started", "normal", "lagging", "critical"] },
        "lastActionDate": { "type": "string", "format": "date-time" },
        "nextActionDate": { "type": "string", "format": "date-time" },
        "noMovementCount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "streamId", "currentBlock", "status", "updatedAt"]
    },
    "Import": {
      "title": "Import",
      "description": "A record of a CSV import",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" },
        "totalStudents": { "type": "number" }
      },
      "required": ["date", "fileName", "totalStudents"]
    },
    "ProgressHistory": {
      "title": "Progress History",
      "description": "A snapshot of a student's progress at a specific time",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "importId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "block": { "type": "number" }
      },
      "required": ["studentId", "importId", "date", "block"]
    },
    "Action": {
      "title": "Action",
      "description": "A retention action taken on a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "result": { "type": "string" },
        "comment": { "type": "string" },
        "nextActionDate": { "type": "string", "format": "date-time" },
        "managerId": { "type": "string" },
        "managerName": { "type": "string" },
        "isCompleted": { "type": "boolean" }
      },
      "required": ["studentId", "date", "type", "result", "managerId"]
    }
  },
  "firestore": {
    "/streams/{streamId}": {
      "schema": { "$ref": "#/entities/Stream" },
      "description": "Stores all streams"
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Stores all students"
    },
    "/imports/{importId}": {
      "schema": { "$ref": "#/entities/Import" },
      "description": "Stores import history"
    },
    "/progress/{progressId}": {
      "schema": { "$ref": "#/entities/ProgressHistory" },
      "description": "Stores student progress history"
    },
    "/actions/{actionId}": {
      "schema": { "$ref": "#/entities/Action" },
      "description": "Stores retention actions"
    }
  }
}
